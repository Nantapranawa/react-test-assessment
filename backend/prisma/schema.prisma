// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int     @id @default(autoincrement())
  email           String  @unique
  name            String?
  nik_user        String  @unique
  talent_solution Int
}

model Employee {
  id                  Int            @id @default(autoincrement())
  no                  Int
  nama                String
  nik                 String         @unique
  bp                  Int
  posisi              String
  eligible            String
  expired             String
  ac_result           String
  phone               String?        @unique
  tc_result           String
  availability_status String         @default("No Invitation")
  usulan_ubis         String         @default("Unknown")
  batches             Batch[]
  notifications       Notification[]
}

model Batch {
  id             Int        @id @default(autoincrement())
  batchName      String?
  location       String
  assessmentDate DateTime
  createdAt      DateTime   @default(now())
  employees      Employee[]
}

model Notification {
  id         Int       @id @default(autoincrement())
  message    String
  type       String // "info", "success", "warning"
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id])
}
