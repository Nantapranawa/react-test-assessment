generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int     @id @default(autoincrement())
  email           String  @unique
  name            String?
  nik_user        String  @unique
  password        String  @default("password123")
  talent_solution Int
  role            String  @default("USER")
}

model EmployeeTS1 {
  id                  Int               @id @default(autoincrement())
  no                  Int
  nama                String
  nik                 String            @unique
  bp                  Int
  posisi              String
  ac_result           String
  eligible            String
  expired             String
  phone               String?           @unique
  availability_status String            @default("No Invitation")
  usulan_ubis         String            @default("Unknown")
  tc_result           String
  updatedAt           DateTime          @default(now()) @updatedAt
  notifications       NotificationTS1[]
  batches             BatchTS1[]        @relation("BatchTS1ToEmployeeTS1")
}

model EmployeeTS2 {
  id                  Int               @id @default(autoincrement())
  no                  Int
  nama                String
  nik                 String            @unique
  bp                  Int
  posisi              String
  ac_result           String
  eligible            String
  expired             String
  phone               String?           @unique
  availability_status String            @default("No Invitation")
  usulan_ubis         String            @default("Unknown")
  tc_result           String
  updatedAt           DateTime          @default(now()) @updatedAt
  notifications       NotificationTS2[]
  batches             BatchTS2[]        @relation("BatchTS2ToEmployeeTS2")
}

model BatchTS1 {
  id             Int           @id @default(autoincrement())
  batchName      String?
  location       String
  assessmentDate DateTime
  createdAt      DateTime      @default(now())
  employees      EmployeeTS1[] @relation("BatchTS1ToEmployeeTS1")
}

model BatchTS2 {
  id             Int           @id @default(autoincrement())
  batchName      String?
  location       String
  assessmentDate DateTime
  createdAt      DateTime      @default(now())
  employees      EmployeeTS2[] @relation("BatchTS2ToEmployeeTS2")
}

model NotificationTS1 {
  id         Int          @id @default(autoincrement())
  message    String
  type       String
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())
  employeeId Int?
  employee   EmployeeTS1? @relation(fields: [employeeId], references: [id])
}

model NotificationTS2 {
  id         Int          @id @default(autoincrement())
  message    String
  type       String
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())
  employeeId Int?
  employee   EmployeeTS2? @relation(fields: [employeeId], references: [id])
}
